# Database Configuration
ConnectionStrings__DefaultConnection=Server=localhost\\SQLEXPRESS;Database=Trackr;Trusted_Connection=True;TrustServerCertificate=True

# JWT Configuration
Jwt__Secret=your-super-secret-jwt-key-here
Jwt__Issuer=Trackr
Jwt__Audience=Trackr

# Spotify Configuration
SpotifyClient__ClientId=your-spotify-client-id
SpotifyClient__ClientSecret=your-spotify-client-secret
SpotifyClient__RedirectUri=https://localhost:7195/callback
SpotifyClient__State=your-random-state-string

# Redis Configuration
Redis__Host=your-redis-host
Redis__Port=6379
Redis__User=default
Redis__Password=your-redis-password

# RabbitMQ Configuration
RabbitMQ__HostName=localhost
RabbitMQ__UserName=admin
RabbitMQ__Password=admin
